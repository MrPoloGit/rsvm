{
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    // Add any extra features as needed
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "streetsidesoftware.code-spell-checker",
        "AndrewNolte.vscode-system-verilog",
        "hediet.vscode-drawio",
        "surfer-project.surfer",
        "stephanvs.dot",
        "tomoki1207.pdf",
        "danielroedl.meld-diff",
        "bmpenuelas.waveform-render",
        "SimonSiefke.svg-preview"
      ]
    }
  },
  "remoteUser": "sv_user",
  "postCreateCommand": "echo 'Container setup complete!'",
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspaces/custom_sv_modules,type=bind,consistency=cached"
  ]
}